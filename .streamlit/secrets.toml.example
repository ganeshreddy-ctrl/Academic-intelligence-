# Copy to .streamlit/secrets.toml (gitignored) for local runs.
# On Streamlit Cloud, paste these into Settings -> Secrets instead.
#
# NEVER commit the real secrets.toml.

OPENROUTER_API_KEY = "sk-or-v1-..."

# Any OpenRouter model with tool-calling support.
# opus-4.8 ($5/$25 per M tok) for advisory/analytical work — the tier shows on
# questions like "give me a better HLID". sonnet-4.5 ($3/$15) is fine for lookups.
AIP_MODEL = "anthropic/claude-opus-4.8"

# Google OAuth — gates the app to @nxtwave.co.in / @nxtwave.tech accounts.
# redirect_uri must exactly match the Authorized redirect URI on the Google OAuth
# client (Google Cloud Console -> Credentials). Use localhost for local runs.
# cookie_secret: any long random string, e.g. python -c "import secrets;print(secrets.token_hex(32))"
[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "change-me-to-a-random-32-byte-hex"
client_id = "<google-oauth-client-id>"
client_secret = "<google-oauth-client-secret>"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
